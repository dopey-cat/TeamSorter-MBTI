    "name": "康宋睿",
    "studentId": "DX125621",
    "college": "东南大学 南工书院",
    "major": "电子信息专业",
    "mbtiType": "ENTJ",
    "scores": {
      "communication": 10,
      "collaboration": 0,
      "problemSolving": 10,
      "projectManagement": 3,
